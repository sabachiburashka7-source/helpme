{
  "version": 2,
  "builds": [
    { "src": "api/generate-image.js", "use": "@vercel/node" },
    { "src": "dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/_expo/(.*)", "dest": "/dist/_expo/$1" },
    { "src": "/favicon.ico", "dest": "/dist/favicon.ico" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/dist/index.html" }
  ]
}
