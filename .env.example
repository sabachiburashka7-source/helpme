# Copy to .env.local and fill in. Expo's bundler inlines EXPO_PUBLIC_*
# values into the JS bundle at build time, so you must `npm run build`
# AFTER setting these for them to take effect in the deployed dist/.
# Get values from Firebase Console → Project settings → Your apps → Web.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
